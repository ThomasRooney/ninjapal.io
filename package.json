{
  "name": "start-zero",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build && bun scripts/fix-css-hash.ts",
    "check": "biome check && tsc --noEmit",
    "check:fix": "biome check --fix",
    "clean": "rm -rf node_modules bun.lock",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "db:seed": "drizzle-kit push --force && bun scripts/seed-demo.ts",
    "db:zero:generate": "drizzle-zero generate --format --output src/server/db/zero-schema.gen.ts",
    "dev": "vite dev",
    "format": "biome format",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "serve": "vite preview",
    "shadcn": "bunx shadcn@canary add",
    "start": "vite start",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "update-packages": "bunx taze -I --recursive",
    "zero-cache": "source .env && zero-cache-dev -p src/server/db/index.ts --log-level debug",
    "email:dev": "bunx react-email dev --dir src/emails --port 3883",
    "email:export": "bunx react-email export --dir src/emails",
    "postinstall": "bun db:zero:generate"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.83",
    "@anthropic-ai/sdk": "^0.104.1",
    "@assistant-ui/react": "^0.14.18",
    "@assistant-ui/react-ai-sdk": "^1.3.35",
    "@assistant-ui/react-markdown": "^0.14.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-avatar": "^1.1.9",
    "@radix-ui/react-checkbox": "^1.3.1",
    "@radix-ui/react-dialog": "^1.1.13",
    "@radix-ui/react-dropdown-menu": "^2.1.14",
    "@radix-ui/react-label": "^2.1.6",
    "@radix-ui/react-navigation-menu": "^1.2.12",
    "@radix-ui/react-select": "^2.2.4",
    "@radix-ui/react-separator": "^1.1.6",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.2",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.11",
    "@radix-ui/react-toggle": "^1.1.8",
    "@radix-ui/react-toggle-group": "^1.1.9",
    "@radix-ui/react-tooltip": "^1.2.6",
    "@react-email/components": "^0.0.38",
    "@react-email/render": "^1.1.0",
    "@rocicorp/zero": "^0.20.2025052100",
    "@tabler/icons-react": "^3.31.0",
    "@tailwindcss/postcss": "^4.1.5",
    "@tailwindcss/vite": "^4.1.5",
    "@tanstack/react-query": "^5.81.2",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-start": "^1.168.25",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.168.18",
    "@vercel/blob": "^2.4.0",
    "ai": "^6.0.202",
    "better-auth": "^1.2.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.40.1",
    "drizzle-zero": "^0.9.2",
    "fetch-to-node": "^2.1.0",
    "jose": "^6.2.3",
    "lucide-react": "^0.503.0",
    "next-themes": "^0.4.6",
    "pg": "^8.15.6",
    "playwright": "^1.53.1",
    "postcss": "^8.5.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.56.2",
    "recharts": "^2.15.3",
    "resend": "^4.5.1",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.2.0",
    "tailwindcss": "^4.1.5",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "vite-tsconfig-paths": "^5.1.4",
    "web-push": "^3.6.7",
    "zod": "^4"
